# Optional overrides for scripts/cpanel-deploy.sh
# Copy to project root as .env.deploy (untracked — do not commit secrets)

# Branch to track
DEPLOY_BRANCH=main

# PHP binary (MultiPHP example: /opt/cpanel/ea-php83/root/usr/bin/php)
DEPLOY_PHP=php

# Leave unset to auto-use ./composer.phar or `composer` in PATH
# DEPLOY_COMPOSER="php composer.phar"

# Set to 1 only if you want seeders on every deploy (usually 0)
DEPLOY_RUN_SEEDER=0

# Remote name
DEPLOY_REMOTE=origin

# Leave 0 for cron. To force once from CLI (CLI wins over this file):
#   DEPLOY_FORCE=1 bash scripts/cpanel-deploy.sh
DEPLOY_FORCE=0

# Keep daily deploy log folders this many days
DEPLOY_LOG_KEEP_DAYS=30

# Webhook secret (must match GitHub webhook secret) — used by /deploy/webhook
# DEPLOY_WEBHOOK_SECRET=change-me-to-a-long-random-string
